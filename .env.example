# FlashDash Environment Configuration Example
# Copy this file to .env and update values for your deployment

# ==============================================================================
# DOMAIN CONFIGURATION
# ==============================================================================

# Frontend Domain - Main web application (React frontend)
FRONTEND_DOMAIN=frontend.fxmail.ai

# Backend Domain - API server (FastAPI backend)
BACKEND_DOMAIN=backend.fxmail.ai

# Email Domain - Main domain for emailing server (e.g., howie@fxmail.ai)
# This is the primary domain for email service (e.g., howie@fxmail.ai)
EMAIL_DOMAIN=fxmail.ai

# Drive Domain - File storage and sharing service
DRIVE_DOMAIN=drive.fxmail.ai

# API Base URL - Used by frontend to connect to backend
API_BASE_URL=https://backend.fxmail.ai

# External HTTPS Base URL - Base URL for email links
# This is used when generating secure links for encrypted emails
EXTERNAL_HTTPS_BASE_URL=https://fxmail.ai

# ==============================================================================
# CORS CONFIGURATION
# ==============================================================================

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=https://frontend.fxmail.ai,https://backend.fxmail.ai,https://fxmail.ai,https://drive.fxmail.ai

# Allowed host headers (comma-separated)
ALLOWED_HOSTS=frontend.fxmail.ai,backend.fxmail.ai,fxmail.ai,drive.fxmail.ai,localhost,127.0.0.1

# ==============================================================================
# BACKEND CONFIGURATION
# ==============================================================================

# Python backend host (0.0.0.0 to listen on all interfaces)
PY_HOST=0.0.0.0

# Python backend port
PY_PORT=8000

# Bundles directory - GrapheneOS build bundles storage
BUNDLES_DIR=/app/bundles
GRAPHENE_BUNDLES_ROOT=/app/bundles

# APK storage directory
APK_STORAGE_DIR=/app/apks

# Debug mode (set to false in production)
DEBUG=false

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ==============================================================================
# SECURITY CONFIGURATION
# ==============================================================================

# Secret key for JWT tokens and encryption
# IMPORTANT: Change this to a long random string in production!
# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-secret-key-in-production-use-long-random-string

# ==============================================================================
# DATABASE CONFIGURATION (Optional)
# ==============================================================================

# PostgreSQL database URL
# Format: postgresql+asyncpg://user:password@host:port/database
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/flashdash_db

# Database pool size
# DATABASE_POOL_SIZE=10

# Database max overflow
# DATABASE_MAX_OVERFLOW=20

# ==============================================================================
# REDIS CONFIGURATION (Optional)
# ==============================================================================

# Redis connection URL
# Format: redis://[password@]host:port[/database]
# REDIS_URL=redis://localhost:6379/0

# Redis password (if required)
# REDIS_PASSWORD=

# Redis max connections
# REDIS_MAX_CONNECTIONS=10

# ==============================================================================
# AWS CONFIGURATION (Optional - for file storage)
# ==============================================================================

# AWS Access Key ID
# AWS_ACCESS_KEY_ID=

# AWS Secret Access Key
# AWS_SECRET_ACCESS_KEY=

# AWS Region
# AWS_REGION=us-east-1

# AWS S3 Bucket
# AWS_S3_BUCKET=

# ==============================================================================
# NOTES
# ==============================================================================
#
# Domain Usage:
# - frontend.fxmail.ai: Main web application (React frontend)
# - backend.fxmail.ai: API server (FastAPI backend)
# - fxmail.ai: Email service (main domain for email addresses)
# - drive.fxmail.ai: Drive/file storage service
#
# For local development, you can use:
# - FRONTEND_DOMAIN=localhost
# - BACKEND_DOMAIN=localhost
# - API_BASE_URL=http://localhost:8000
# - EXTERNAL_HTTPS_BASE_URL=http://localhost
#
# For production, ensure:
# 1. All domains point to your server IP
# 2. SSL/TLS is configured (Cloudflare recommended)
# 3. SECRET_KEY is changed to a secure random string
# 4. DEBUG is set to false
# 5. Database and Redis are configured (if using)
