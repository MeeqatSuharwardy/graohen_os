# Code Signing Configuration
# Copy this file to .env and fill in your certificate details
# Or set these as environment variables before building

# Path to your code signing certificate (.pfx file)
# Can be absolute path or relative to this directory
CSC_LINK=./certificate.pfx

# Password for the certificate
CSC_KEY_PASSWORD=your-certificate-password

# Optional: Custom timestamp server
# CSC_TIMESTAMP_SERVER=http://timestamp.digicert.com
